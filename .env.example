# Environment Variables for IaC Orchestrator
# Copy this file to .env and fill in your keys.

# LLM Provider — choose "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Infracost (required for cost estimation)
INFRACOST_API_KEY=ico-...

# Model Configuration (optional overrides)
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Pipeline Configuration
# MAX_ITERATIONS=5
# SECURITY_SCORE_THRESHOLD=90
